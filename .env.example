# CamPark Environment Configuration
# For Google Cloud deployment - update values for production

# ============================================
# REQUIRED: Google Cloud VM Settings
# ============================================

# Your Google Cloud VM static IP (MUST SET THIS!)
EXTERNAL_IP=YOUR_STATIC_IP_HERE

# ============================================
# Database Configuration
# ============================================

DATABASE_URL=postgresql://campark:changeme_poc@postgres:5432/campark
POSTGRES_PASSWORD=changeme_poc

# ============================================
# Storage Paths
# ============================================

# Paths (inside containers)
FTP_INGEST_PATH=/data/ftp
IMAGE_ROOT=/data/images

# ============================================
# FTP Server Configuration
# ============================================

# FTP server settings - IMPORTANT: Set EXTERNAL_IP above!
FTP_PUBLICHOST=YOUR_STATIC_IP_HERE
FTP_PASSIVE_PORTS=30000:30049

# Camera FTP credentials
CAM001_FTP_USER=cam001
CAM001_FTP_PASS=cam001pass

# ============================================
# LAPI WebSocket (4G Camera) Configuration
# ============================================

# Port for LAPI WebSocket server (cameras connect TO this)
LAPI_WS_PORT=8765

# ============================================
# Snapshot Polling Configuration
# ============================================

# RTSP snapshot grab interval (seconds)
RTSP_INTERVAL=10.0

# HTTP snapshot poll interval (seconds)
HTTP_SNAP_INTERVAL=10.0

# ============================================
# YOLO Detection Settings
# ============================================

YOLO_CONFIDENCE=0.50
YOLO_MODEL=yolov8n.pt
OVERLAP_THRESHOLD=0.30
POLL_INTERVAL=1.0

# ============================================
# Health Monitoring
# ============================================

ENABLE_HEALTH_MONITOR=true
HEALTH_INTERVAL_SECONDS=30
STALE_SECONDS=150
OFFLINE_SECONDS=300

# ============================================
# Security & Admin Access
# ============================================

# Admin panel credentials (CHANGE FOR PRODUCTION!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_poc

# API key enforcement
REQUIRE_API_KEY=true
API_KEY=your-secure-api-key-here

# Flask secret key (generate random string)
SECRET_KEY=change-this-to-random-32-character-string

# ============================================
# Optional Features
# ============================================

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Debug mode (set to false for production)
DEBUG=false
FLASK_ENV=production
